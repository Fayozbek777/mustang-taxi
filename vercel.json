{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/products.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/products",
      "dest": "/api/products.py"
    },
    {
      "src": "/api/products/(.*)",
      "dest": "/api/products.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/favicon.png",
      "dest": "/favicon.png"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ]
}
